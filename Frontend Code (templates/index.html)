<!DOCTYPE html>
<html>
<head>
    <title>Number Plate Detection</title>
    <style>
        body {
            font-family: Arial;
            text-align: center;
            background: #f4f4f4;
        }
        .container {
            margin-top: 50px;
        }
        input[type=file] {
            padding: 10px;
        }
        button {
            padding: 10px 20px;
            background: green;
            color: white;
            border: none;
        }
        img {
            margin-top: 20px;
            width: 400px;
        }
        .result {
            margin-top: 20px;
            font-size: 20px;
            color: blue;
        }
    </style>
</head>
<body>

<div class="container">
    <h2>🚗 Vehicle Number Plate Detection</h2>

    <form method="POST" enctype="multipart/form-data">
        <input type="file" name="image" required>
        <br><br>
        <button type="submit">Upload & Detect</button>
    </form>

    {% if image_path %}
        <img src="{{ image_path }}">
    {% endif %}

    {% if text %}
        <div class="result">
            <b>Detected Number:</b> {{ text }}
        </div>
    {% endif %}
</div>

</body>
</html>
